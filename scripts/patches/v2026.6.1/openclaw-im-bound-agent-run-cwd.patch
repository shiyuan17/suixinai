+  agentId: string,
+  overrideCwd?: unknown,
+  env: NodeJS.ProcessEnv = process.env,
+): string | undefined {
+  const explicit = readStringValue(overrideCwd)?.trim();
+  if (explicit) {
+    return stripNullBytes(resolveUserPath(explicit, env));
+  }
+  const configured = resolveAgentConfig(cfg, normalizeAgentId(agentId))?.cwd?.trim();
+  const fallback = cfg.agents?.defaults?.cwd?.trim();
+  const resolved = configured || fallback;
+  return resolved ? stripNullBytes(resolveUserPath(resolved, env)) : undefined;
+}
