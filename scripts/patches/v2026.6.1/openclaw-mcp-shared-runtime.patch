+  it("shares MCP runtimes across sessions with identical MCP config fingerprints", async () => {
+    const created: string[] = [];
+    const disposed: string[] = [];
+    const createRuntime: RuntimeFactory = (params) => {
+      const runtime = makeRuntime([{ toolName: "bundle_probe", description: "Bundle MCP probe" }]);
+      created.push(params.sessionId);
+      return {
+        ...runtime,
+        sessionId: params.sessionId,
+        sessionKey: params.sessionKey,
+        workspaceDir: params.workspaceDir,
+        configFingerprint: params.configFingerprint ?? "fingerprint",
+        dispose: async () => {
+          disposed.push(params.sessionId);
+        },
+      };
+    };
+    const manager = testing.createSessionMcpRuntimeManager({ createRuntime });
+
+    const runtimeA = await manager.getOrCreate({
+      sessionId: "session-a",
+      sessionKey: "agent:test:session-a",
+      workspaceDir: "/workspace",
+      cfg: { mcp: { servers: { sharedProbe: { command: "node", args: ["server.mjs"] } } } },
+    });
+    const runtimeB = await manager.getOrCreate({
+      sessionId: "session-b",
+      sessionKey: "agent:test:session-b",
+      workspaceDir: "/workspace",
+      cfg: { mcp: { servers: { sharedProbe: { command: "node", args: ["server.mjs"] } } } },
+    });
+
+    expect(runtimeA).toBe(runtimeB);
+    expect(created).toEqual(["session-a"]);
+    expect(manager.peekSession({ sessionId: "session-a" })).toBe(runtimeA);
+    expect(manager.peekSession({ sessionId: "session-b" })).toBe(runtimeA);
+    expect(manager.peekSession({ sessionKey: "agent:test:session-b" })).toBe(runtimeA);
+    expect(manager.listSessionIds().toSorted()).toEqual(["session-a", "session-b"]);
+
+    await manager.disposeSession("session-a");
+
+    expect(disposed).toEqual([]);
+    expect(manager.peekSession({ sessionId: "session-a" })).toBeUndefined();
+    expect(manager.peekSession({ sessionId: "session-b" })).toBe(runtimeA);
+    expect(manager.listSessionIds()).toEqual(["session-b"]);
+
+    await manager.disposeSession("session-b");
+
+    expect(disposed).toEqual(["session-a"]);
+    expect(manager.listSessionIds()).toEqual([]);
+  });
+
+  it("releases the old shared runtime when a session moves to a new MCP fingerprint", async () => {
+    const disposed: string[] = [];
+    const createRuntime: RuntimeFactory = (params) => ({
+      ...makeRuntime([{ toolName: "bundle_probe", description: "Bundle MCP probe" }]),
+      sessionId: params.sessionId,
+      sessionKey: params.sessionKey,
+      workspaceDir: params.workspaceDir,
+      configFingerprint: params.configFingerprint ?? "fingerprint",
+      dispose: async () => {
+        disposed.push(params.sessionId);
+      },
+    });
+    const manager = testing.createSessionMcpRuntimeManager({ createRuntime });
+
+    const runtimeA = await manager.getOrCreate({
+      sessionId: "session-a",
+      sessionKey: "agent:test:session-a",
+      workspaceDir: "/workspace",
+      cfg: { mcp: { servers: { sharedProbe: { command: "node", args: ["server-a.mjs"] } } } },
+    });
+    const runtimeB = await manager.getOrCreate({
+      sessionId: "session-b",
+      sessionKey: "agent:test:session-b",
+      workspaceDir: "/workspace",
+      cfg: { mcp: { servers: { sharedProbe: { command: "node", args: ["server-a.mjs"] } } } },
+    });
+
+    expect(runtimeA).toBe(runtimeB);
+
+    const runtimeC = await manager.getOrCreate({
+      sessionId: "session-b",
+      sessionKey: "agent:test:session-b",
+      workspaceDir: "/workspace",
+      cfg: { mcp: { servers: { sharedProbe: { command: "node", args: ["server-b.mjs"] } } } },
+    });
+
+    expect(runtimeC).not.toBe(runtimeA);
+    expect(disposed).toEqual([]);
+    expect(manager.peekSession({ sessionId: "session-a" })).toBe(runtimeA);
+    expect(manager.peekSession({ sessionId: "session-b" })).toBe(runtimeC);
+
+    await manager.disposeSession("session-a");
+
+    expect(disposed).toEqual(["session-a"]);
+    expect(manager.peekSession({ sessionId: "session-b" })).toBe(runtimeC);
+  });
