diff --git a/src/shared/runtime-import.test.ts b/src/shared/runtime-import.test.ts
new file mode 100644
index 0000000000..8441f70a8a
--- /dev/null
+++ b/src/shared/runtime-import.test.ts
@@ -0,0 +1,39 @@
+import path from "node:path";
+import { pathToFileURL } from "node:url";
+import { describe, expect, it } from "vitest";
+import { resolveRuntimeModuleUrl } from "./runtime-import.js";
+
+describe("resolveRuntimeModuleUrl", () => {
+  it("resolves runtime modules under dist when the base module is the gateway bundle", () => {
+    const runtimeRoot = path.resolve("cfmind");
+    const baseUrl = pathToFileURL(path.join(runtimeRoot, "gateway-bundle.mjs")).href;
+
+    expect(
+      resolveRuntimeModuleUrl(baseUrl, ["./subagent-registry.runtime", ".js"]),
+    ).toBe(
+      pathToFileURL(path.join(runtimeRoot, "dist", "subagent-registry.runtime.js")).href,
+    );
+  });
+
+  it("keeps normal dist-relative resolution for non-bundle modules", () => {
+    const runtimeRoot = path.resolve("cfmind");
+    const baseUrl = pathToFileURL(path.join(runtimeRoot, "dist", "subagent-registry.js")).href;
+
+    expect(
+      resolveRuntimeModuleUrl(baseUrl, ["./subagent-registry.runtime", ".js"]),
+    ).toBe(
+      pathToFileURL(path.join(runtimeRoot, "dist", "subagent-registry.runtime.js")).href,
+    );
+  });
+
+  it("does not rewrite unrelated root modules", () => {
+    const runtimeRoot = path.resolve("cfmind");
+    const baseUrl = pathToFileURL(path.join(runtimeRoot, "openclaw.mjs")).href;
+
+    expect(
+      resolveRuntimeModuleUrl(baseUrl, ["./subagent-registry.runtime", ".js"]),
+    ).toBe(
+      pathToFileURL(path.join(runtimeRoot, "subagent-registry.runtime.js")).href,
+    );
+  });
+});
diff --git a/src/shared/runtime-import.ts b/src/shared/runtime-import.ts
index e76d407fa9..3ccaad6487 100644
--- a/src/shared/runtime-import.ts
+++ b/src/shared/runtime-import.ts
@@ -1,6 +1,29 @@
+import path from "node:path";
+import { fileURLToPath } from "node:url";
+
+const GATEWAY_BUNDLE_BASENAME = "gateway-bundle.mjs";
+
+export function resolveRuntimeModuleUrl(
+  baseUrl: string,
+  parts: readonly string[],
+): string {
+  const specifier = parts.join("");
+  if (specifier.startsWith("./")) {
+    try {
+      const basePath = fileURLToPath(baseUrl);
+      if (path.basename(basePath) === GATEWAY_BUNDLE_BASENAME) {
+        return new URL(`./dist/${specifier.slice(2)}`, baseUrl).href;
+      }
+    } catch {
+      // Keep default URL resolution for non-file URLs and malformed bases.
+    }
+  }
+  return new URL(specifier, baseUrl).href;
+}
+
 export async function importRuntimeModule<T>(
   baseUrl: string,
   parts: readonly string[],
 ): Promise<T> {
-  return (await import(new URL(parts.join(""), baseUrl).href)) as T;
+  return (await import(resolveRuntimeModuleUrl(baseUrl, parts))) as T;
 }
