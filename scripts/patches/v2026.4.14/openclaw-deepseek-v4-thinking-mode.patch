@@ -0,0 +1,119 @@
+import type { StreamFn } from "@mariozechner/pi-agent-core";
+import { streamSimple } from "@mariozechner/pi-ai";
+import type { ThinkLevel } from "../../auto-reply/thinking.js";
+
+type ReasoningContentThinkingType = "enabled" | "disabled";
+
+type ReasoningContentThinkingTarget = {
+  id?: unknown;
+  provider?: unknown;
+};
+
+type ReasoningContentThinkingMatcher = (model: ReasoningContentThinkingTarget) => boolean;
+
+type ReasoningContentThinkingModeWrapperOptions = {
+  isTargetModel: ReasoningContentThinkingMatcher;
+  enabledType?: ReasoningContentThinkingType;
+  disabledType?: ReasoningContentThinkingType;
+  dropReasoningParamsWhenDisabled?: boolean;
+};
+
+function isRecord(value: unknown): value is Record<string, unknown> {
+  return !!value && typeof value === "object" && !Array.isArray(value);
+}
+
+function resolveThinkingType(
+  thinkingLevel: ThinkLevel | undefined,
+  options: ReasoningContentThinkingModeWrapperOptions,
+): ReasoningContentThinkingType {
+  if (thinkingLevel === "off") {
+    return options.disabledType ?? "disabled";
+  }
+  return options.enabledType ?? "enabled";
+}
+
+function removeConflictingReasoningParams(payload: Record<string, unknown>): void {
+  delete payload.reasoning;
+  delete payload.reasoning_effort;
+  delete payload.reasoningEffort;
+}
+
+export function isDeepSeekV4ModelId(modelId: unknown): boolean {
+  return typeof modelId === "string" && /^deepseek-v4(?:[-_.]|$)/i.test(modelId.trim());
+}
+
+function isDeepSeekV4Model(model: ReasoningContentThinkingTarget): boolean {
+  // Provider id can be custom_*. DeepSeek V4 is identified by the
+  // upstream model id instead.
+  return isDeepSeekV4ModelId(model.id);
+}
+
+function isXiaomiProviderModel(model: ReasoningContentThinkingTarget): boolean {
+  return model.provider === "xiaomi";
+}
+
+export function createReasoningContentThinkingModeWrapper(
+  baseStreamFn: StreamFn | undefined,
+  thinkingLevel: ThinkLevel | undefined,
+  options: ReasoningContentThinkingModeWrapperOptions,
+): StreamFn {
+  const underlying = baseStreamFn ?? streamSimple;
+  const thinkingType = resolveThinkingType(thinkingLevel, options);
+  const dropReasoningParamsWhenDisabled = options.dropReasoningParamsWhenDisabled ?? true;
+
+  return (model, context, streamOptions) => {
+    if (!options.isTargetModel(model)) {
+      return underlying(model, context, streamOptions);
+    }
+
+    const originalOnPayload = streamOptions?.onPayload;
+    return underlying(model, context, {
+      ...streamOptions,
+      onPayload: (payload) => {
+        if (isRecord(payload)) {
+          const hasExplicitThinking = Object.hasOwn(payload, "thinking");
+          if (!hasExplicitThinking || payload.thinking === undefined) {
+            payload.thinking = { type: thinkingType };
+          }
+
+          if (dropReasoningParamsWhenDisabled && payload.thinking && isRecord(payload.thinking)) {
+            const type = payload.thinking.type;
+            if (type === (options.disabledType ?? "disabled")) {
+              removeConflictingReasoningParams(payload);
+            }
+          }
+        }
+        return originalOnPayload?.(payload, model);
+      },
+    });
+  };
+}
+
+/**
+ * DeepSeek V4 defaults to thinking mode. In tool-use turns, DeepSeek requires
+ * the previous assistant `reasoning_content` to be replayed. Match by model id
+ * so custom providers serving DeepSeek V4 get the same fix across API formats
+ * without relying on provider ids.
+ */
+export function createDeepSeekThinkingModeWrapper(
+  baseStreamFn: StreamFn | undefined,
+  thinkingLevel?: ThinkLevel,
+): StreamFn {
+  return createReasoningContentThinkingModeWrapper(baseStreamFn, thinkingLevel, {
+    isTargetModel: isDeepSeekV4Model,
+  });
+}
+
+/**
+ * Xiaomi MiMo documents the same `reasoning_content` replay contract for
+ * tool-use continuations. Scope by provider so newly added MiMo model ids
+ * inherit the same payload behavior without a model whitelist.
+ */
+export function createXiaomiThinkingModeWrapper(
+  baseStreamFn: StreamFn | undefined,
+  thinkingLevel?: ThinkLevel,
+): StreamFn {
+  return createReasoningContentThinkingModeWrapper(baseStreamFn, thinkingLevel, {
+    isTargetModel: isXiaomiProviderModel,
+  });
+}
